# Copy this file to .env for local development (optional)
# On Vercel, set these as Environment Variables in the project settings

# MongoDB Atlas connection string (required on Vercel)
# Get this from: MongoDB Atlas → Your Cluster → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=

# Admin panel password (default: portfolio2026)
ADMIN_PASSWORD=portfolio2026

# Enable verbose logging (optional)
DEBUG=0
